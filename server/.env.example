# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_here

# ─── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase Admin SDK ───────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Service Accounts
FIREBASE_ACCOUNT_PROJECT_ID=your_firebase_project_id
FIREBASE_ACCOUNT_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# ─── Judge0 Code Execution (via RapidAPI) ─────────────────────────────────────
# Subscribe at: https://rapidapi.com/judge0-official/api/judge0-ce
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your_rapidapi_key_here
JUDGE0_API_HOST=judge0-ce.p.rapidapi.com
